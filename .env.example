# ============================================================
# 환경 변수 예시 — 실제 값으로 채워 `.env`로 복사해 사용하세요.
#   cp .env.example .env
# 모든 경로는 프로젝트 루트 기준으로 자동 설정되므로, 기본 동작에는
# 아래 값들이 필수가 아닙니다. (자세한 설명은 RUN.md §5 / §9 참고)
# ============================================================

# ---- 가상 피팅(Virtual Try-On) 백엔드 선택 ----
# api      = fal-ai 클라우드 API (기본값, FAL_KEY 필요)
# ondevice = 온디바이스 Mobile-VTON, RPi 클러스터 (RUN.md §9)
VTON_BACKEND=api

# api 백엔드 사용 시 필요. 미설정 시 /tryon 만 비활성, 추천 파이프라인은 정상 동작.
FAL_KEY=your_fal_api_key_here

# ---- 온디바이스 백엔드(VTON_BACKEND=ondevice)에서만 사용 (선택) ----
# 기본값은 src/tryon_ondevice.py 참조. 클러스터 구성에 맞게 덮어쓰세요.
# VTON_PEERS=192.168.100.2 192.168.100.3 192.168.100.4
# VTON_STEPS=6
# VTON_CHECKPOINT_PATH=src/ondevice_vton/checkpoint
# VTON_PYTHON=.venv/bin/python
